import os
import librosa
import librosa.display
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns

from IPython.display import Audio
dataset_path = "/content/audio_speech_actors_01-24"
os.listdir(dataset_path)[:5]
actors = sorted(os.listdir(dataset_path))

print("Total Actors:", len(actors))
total_files = 0

for actor in actors:
    actor_path = os.path.join(dataset_path, actor)
    total_files += len(os.listdir(actor_path))

print("Total Audio Files:", total_files)
emotion_dict = {
    "01": "Neutral",
    "02": "Calm",
    "03": "Happy",
    "04": "Sad",
    "05": "Angry",
    "06": "Fear",
    "07": "Disgust",
    "08": "Surprised"
}
data = []

for actor in actors:

    actor_path = os.path.join(dataset_path, actor)

    for file in os.listdir(actor_path):

        parts = file.replace(".wav","").split("-")

        emotion = emotion_dict[parts[2]]

        actor_id = int(parts[-1])

        gender = "Male" if actor_id % 2 else "Female"

        data.append([
            file,
            emotion,
            gender,
            actor_id,
            os.path.join(actor_path,file)
        ])

df = pd.DataFrame(data, columns=[
    "File",
    "Emotion",
    "Gender",
    "Actor",
    "Path"
])

df.head()
df.info()
df.isnull().sum()
plt.figure(figsize=(10,5))

sns.countplot(
    data=df,
    x="Emotion",
    order=df["Emotion"].value_counts().index
)

plt.title("Emotion Distribution")
plt.xticks(rotation=45)
plt.show()
plt.figure(figsize=(6,5))

sns.countplot(
    data=df,
    x="Gender"
)

plt.title("Gender Distribution")
plt.show()
plt.figure(figsize=(12,5))

sns.countplot(
    data=df,
    x="Actor"
)

plt.title("Number of Audio Files per Actor")
plt.show()
sample = df.iloc[0]

print(sample["Emotion"])
print(sample["Gender"])

Audio(sample["Path"])
audio, sr = librosa.load(sample["Path"], sr=None)

print("Sampling Rate:", sr)

print("Audio Shape:", audio.shape)
plt.figure(figsize=(14,4))

librosa.display.waveshow(audio, sr=sr)

plt.title("Waveform")

plt.show()
X = librosa.stft(audio)

Xdb = librosa.amplitude_to_db(abs(X))

plt.figure(figsize=(14,5))

librosa.display.specshow(
    Xdb,
    sr=sr,
    x_axis='time',
    y_axis='hz'
)

plt.colorbar()

plt.title("Spectrogram")

plt.show()
mel = librosa.feature.melspectrogram(
    y=audio,
    sr=sr
)

mel_db = librosa.power_to_db(mel)

plt.figure(figsize=(14,5))

librosa.display.specshow(
    mel_db,
    sr=sr,
    x_axis='time',
    y_axis='mel'
)

plt.colorbar()

plt.title("Mel Spectrogram")

plt.show()
durations = []

for path in df["Path"]:

    y, sr = librosa.load(path, sr=None)

    durations.append(librosa.get_duration(y=y, sr=sr))

df["Duration"] = durations
df["Duration"].describe()
plt.figure(figsize=(8,5))

sns.histplot(df["Duration"], bins=20)

plt.title("Audio Duration Distribution")

plt.show()
df.to_csv("ravdess_metadata.csv", index=False)
