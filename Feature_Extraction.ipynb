def extract_mel(path):

    audio = preprocess_audio(path)

    mel = librosa.feature.melspectrogram(
        y=audio,
        sr=16000,
        n_mels=128
    )

    mel_db = librosa.power_to_db(
        mel,
        ref=np.max
    )

    return mel_db
